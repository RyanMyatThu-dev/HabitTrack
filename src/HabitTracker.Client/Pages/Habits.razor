@page "/habits"
@using HabitTracker.Application.DTOs
@using HabitTracker.Application.Services
@inject IHabitService HabitService

<PageTitle>My Habits – Habit Tracker</PageTitle>

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-bold text-slate-900">My Habits</h2>
            <p class="text-slate-500 text-sm mt-1">Manage and track all your habits</p>
        </div>
        <button @onclick="() => ShowAddModal = true" class="btn btn-primary flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            New Habit
        </button>
    </div>

    @if (HabitList == null)
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @for (int i = 0; i < 3; i++)
            {
                <div class="card animate-pulse">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-12 h-12 rounded-xl bg-slate-200"></div>
                        <div class="flex-1 space-y-2">
                            <div class="h-4 bg-slate-200 rounded w-3/4"></div>
                            <div class="h-3 bg-slate-200 rounded w-1/2"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!HabitList.Any())
    {
        <div class="card text-center py-16 border-dashed border-2 border-slate-200">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
                🌱
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">No habits yet</h3>
            <p class="text-slate-500 mb-6 max-w-sm mx-auto">Start your journey to a better lifestyle by adding your first habit.</p>
            <button @onclick="() => ShowAddModal = true" class="btn btn-primary">Create First Habit</button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var habit in HabitList)
            {
                <div class="card group hover:shadow-md transition-all duration-200 hover:-translate-y-0.5">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl flex-shrink-0" style="background-color: @(habit.Color)15;">
                                @habit.Icon
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-900 leading-tight">@habit.Name</h3>
                                @if (!string.IsNullOrEmpty(habit.Description))
                                {
                                    <p class="text-xs text-slate-500 mt-0.5">@habit.Description</p>
                                }
                            </div>
                        </div>
                        <button @onclick="() => DeleteHabit(habit.Id)" class="opacity-0 group-hover:opacity-100 text-slate-400 hover:text-red-500 transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                    
                    <div class="grid grid-cols-3 gap-3 mt-4 pt-4 border-t border-slate-100">
                        <div class="text-center">
                            <div class="text-lg font-bold text-slate-900">@habit.CurrentStreak</div>
                            <div class="text-xs text-slate-500">Streak</div>
                        </div>
                        <div class="text-center border-x border-slate-100">
                            <div class="text-lg font-bold text-slate-900">@habit.CompletionCount</div>
                            <div class="text-xs text-slate-500">Total</div>
                        </div>
                        <div class="text-center">
                            <div class="text-lg font-bold @(habit.IsCompletedToday ? "text-green-600" : "text-slate-400")">
                                @(habit.IsCompletedToday ? "✓" : "–")
                            </div>
                            <div class="text-xs text-slate-500">Today</div>
                        </div>
                    </div>

                    <button @onclick="() => ToggleHabit(habit.Id)"
                        class="mt-4 w-full py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 @(habit.IsCompletedToday ? "bg-green-50 text-green-700 border border-green-200" : "bg-primary-600 text-white hover:bg-primary-700")">
                        @(habit.IsCompletedToday ? "✓ Completed Today" : "Mark Complete")
                    </button>
                </div>
            }
        </div>
    }
</div>

@if (ShowAddModal)
{
    <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden">
            <div class="p-8">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-2xl font-bold text-slate-900">New Habit</h3>
                    <button @onclick="() => ShowAddModal = false" class="w-8 h-8 flex items-center justify-center rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Habit Name *</label>
                        <input @bind="NewHabit.Name" type="text" placeholder="e.g. Read 30 minutes"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all text-slate-900 placeholder-slate-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Description</label>
                        <input @bind="NewHabit.Description" type="text" placeholder="Optional description"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all text-slate-900 placeholder-slate-400" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Icon (Emoji)</label>
                        <div class="flex gap-2">
                            @foreach (var emoji in EmojiPresets)
                            {
                                <button @onclick="() => NewHabit.Icon = emoji"
                                    class="w-10 h-10 text-xl rounded-xl transition-all @(NewHabit.Icon == emoji ? "ring-2 ring-primary-500 bg-primary-50 scale-110" : "hover:bg-slate-100")">
                                    @emoji
                                </button>
                            }
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1.5">Theme Color</label>
                        <div class="flex gap-2">
                            @foreach (var color in ColorPresets)
                            {
                                <button @onclick="() => NewHabit.Color = color"
                                    class="w-8 h-8 rounded-full border-2 transition-all @(NewHabit.Color == color ? "border-slate-900 scale-110 shadow-md" : "border-transparent hover:scale-105")"
                                    style="background-color: @color"></button>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-6 bg-slate-50 flex gap-3 border-t border-slate-100">
                <button @onclick="() => { ShowAddModal = false; NewHabit = new(); }" class="btn flex-1 bg-white border border-slate-200 text-slate-600 hover:bg-slate-50">Cancel</button>
                <button @onclick="SaveHabit" disabled="@string.IsNullOrWhiteSpace(NewHabit.Name)" class="btn flex-1 btn-primary disabled:opacity-50 disabled:cursor-not-allowed">Create Habit</button>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<HabitDto>? HabitList;
    private bool ShowAddModal;
    private CreateHabitRequest NewHabit = new() { Icon = "🔥", Color = "#4F46E5" };

    private string[] EmojiPresets = { "🔥", "💪", "📚", "🏃", "💧", "🧘", "🍎", "😴" };
    private string[] ColorPresets = { "#4F46E5", "#EF4444", "#10B981", "#F59E0B", "#EC4899", "#8B5CF6", "#06B6D4", "#84CC16" };

    protected override async Task OnInitializedAsync() => await LoadHabits();

    private async Task LoadHabits()
    {
        HabitList = await HabitService.GetActiveHabitsAsync();
    }

    private async Task ToggleHabit(Guid id)
    {
        await HabitService.ToggleHabitCompletionAsync(id, DateTime.UtcNow);
        await LoadHabits();
    }

    private async Task DeleteHabit(Guid id)
    {
        await HabitService.DeleteHabitAsync(id);
        await LoadHabits();
    }

    private async Task SaveHabit()
    {
        if (string.IsNullOrWhiteSpace(NewHabit.Name)) return;
        await HabitService.CreateHabitAsync(NewHabit);
        ShowAddModal = false;
        NewHabit = new() { Icon = "🔥", Color = "#4F46E5" };
        await LoadHabits();
    }
}
